{
  "info": {
    "_postman_id": "notification-api-collection",
    "name": "Notification API",
    "description": "Tutte le chiamate API del progetto Notification (porta 8085)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8085",
      "type": "string",
      "enabled": true
    }
  ],
  "item": [
    {
      "name": "Notifications",
      "description": "Endpoint per la gestione delle notifiche (/api/notification)",
      "item": [
        {
          "name": "Create Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notification/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notification", "create"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Richiesta ferie\",\n  \"body\": \"Giovanni Rossi ha richiesto ferie dal 01/01/2025 al 10/01/2025\",\n  \"type\": \"VACATION_REQUEST\",\n  \"payload\": {\n    \"startDate\": \"2025-01-01\",\n    \"endDate\": \"2025-01-10\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Crea una nuova notifica. Restituisce la notifica creata."
          },
          "response": []
        },
        {
          "name": "Get All Notifications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notification",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notification"]
            },
            "description": "Recupera la lista di tutte le notifiche."
          },
          "response": []
        },
        {
          "name": "Get Notification by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notification/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notification", "1"]
            },
            "description": "Recupera una notifica tramite il suo ID."
          },
          "response": []
        },
        {
          "name": "Update Notification",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notification/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notification", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Richiesta ferie aggiornata\",\n  \"body\": \"Giovanni Rossi ha aggiornato la richiesta ferie\",\n  \"type\": \"VACATION_REQUEST\",\n  \"payload\": {\n    \"startDate\": \"2025-02-01\",\n    \"endDate\": \"2025-02-10\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Aggiorna una notifica esistente tramite il suo ID."
          },
          "response": []
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notification/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notification", "1"]
            },
            "description": "Elimina una notifica tramite il suo ID."
          },
          "response": []
        }
      ]
    },
